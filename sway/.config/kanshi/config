profile laptop_mobile {
    output eDP-1 enable position 0,0

    exec ln -sf ~/.config/sway/setups/laptop_mobile ~/.config/sway/current_setup && swaymsg reload
}

profile laptop_home {
    output eDP-1 disable
    output "Microstep MPG 274U E16M CF0H215700095" enable

    exec ln -sf ~/.config/sway/setups/laptop_home ~/.config/sway/current_setup && swaymsg reload
}
